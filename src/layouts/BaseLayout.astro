---
import '../styles/global.css';
import type { Locale } from '../data/site';
import { localeLabels, otherLocale } from '../data/site';

type Props = {
  title: string;
  description: string;
  locale: Locale;
  alternatePath?: string;
};

const { title, description, locale, alternatePath = `/${otherLocale(locale)}` } = Astro.props;
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Figtree:wght@400;500;600;700&family=Noto+Serif+TC:wght@500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="grain-field" aria-hidden="true"></div>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <a class="brand" href={`/${locale}`}>Ting-An Lin / 林庭安</a>
      <a class="language-switch" href={alternatePath} aria-label={`Switch language to ${localeLabels[otherLocale(locale)]}`}>
        {localeLabels[otherLocale(locale)]}
      </a>
    </header>
    <main id="main">
      <slot />
    </main>
  </body>
</html>
