---
import ProjectCard from './ProjectCard.astro';
import type { Locale } from '../data/site';
import { projects } from '../data/site';

type Props = {
  locale: Locale;
  start?: number;
  limit?: number;
};

const { locale, start = 0, limit } = Astro.props;
const visibleProjects = (limit === undefined ? projects.slice(start) : projects.slice(start, start + limit));
---
<div class="portfolio-grid">
  {visibleProjects.map((project, index) => <ProjectCard project={project} locale={locale} featured={start === 0 && index === 0} />)}
</div>
